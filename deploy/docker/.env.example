# Copy this file to .env and replace the absolute paths for your machine.
MISSION_PLANNER_PATH=/absolute/path/to/mission_planner
PUBLIC_BASE_URL=http://127.0.0.1:8081
BACKEND_CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
BACKEND_CORS_ALLOW_CREDENTIALS=false
ROS2_WS_PATH=/absolute/path/to/ros2_ws
LOCAL_MODEL_ROOT=/absolute/path/to/models
INSTALL_LOCAL_LLM=false
TORCH_VERSION=2.8.0
TORCH_WHL_CHANNEL=cu128
SEMANTIC_LLM_ENABLED=false
SEMANTIC_LLM_PROVIDER=disabled
SEMANTIC_LLM_BASE_URL=
SEMANTIC_LLM_API_KEY=
SEMANTIC_LLM_MODEL=
SEMANTIC_LLM_TIMEOUT_SEC=30
SEMANTIC_LLM_LOCAL_MODEL_PATH=/workspace/models/Qwen3-VL-4B-Instruct
SEMANTIC_LLM_LOCAL_ADAPTER_PATH=/workspace/mission_planner/data/models/semantic_sft/active
SEMANTIC_LLM_LOCAL_DEVICE=cuda
SEMANTIC_LLM_LOCAL_DTYPE=auto
SEMANTIC_LLM_LOCAL_MAX_NEW_TOKENS=128
SEMANTIC_LLM_LOCAL_TRUST_REMOTE_CODE=true
ROS_DOMAIN_ID=0
RMW_IMPLEMENTATION=rmw_cyclonedds_cpp
ROS_LOCALHOST_ONLY=0
TZ=Asia/Shanghai
UBUNTU_APT_MIRROR=http://mirrors.tuna.tsinghua.edu.cn/ubuntu
UBUNTU_SECURITY_MIRROR=http://mirrors.tuna.tsinghua.edu.cn/ubuntu
ROS2_APT_MIRROR=http://packages.ros.org/ros2/ubuntu
ROS_KEY_URL=https://raw.githubusercontent.com/ros/rosdistro/master/ros.key
PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True
SEMANTIC_LLM_LOCAL_LOAD_IN_4BIT=true
SEMANTIC_LLM_LOCAL_BNB_COMPUTE_DTYPE=float16

CLOUDFLARE_TUNNEL_TOKEN=
BACKEND_CORS_ALLOW_ORIGIN_REGEX=
